# =========================================================================
# CODEBRAWL MULTIPLAYER ARENA - CENTRAL DEVOPS ENV CONFIGURATION TEMPLATE
# =========================================================================
# Copy this file to '.env' at the root level and customize values.
# The services inside docker-compose will automatically read this file.

# -------------------------------------------------------------------------
# BACKEND API & SOCKET SERVER CONFIGURATION
# -------------------------------------------------------------------------
BACKEND_PORT=5000
MONGO_URI=mongodb://admin:password@mongodb:27017/codingarena?authSource=admin
JWT_SECRET=production_grade_super_secret_session_key_to_be_replaced_on_aws
GEMINI_API_KEY=AIzaSyPlaceholderKeyForGeminiAIGenerationModel

# -------------------------------------------------------------------------
# REDIS CACHE & BULLMQ QUEUE SERVICE
# -------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# -------------------------------------------------------------------------
# CODE EXECUTION MICROSERVICE
# -------------------------------------------------------------------------
EXECUTION_PORT=5001
EXECUTION_SERVICE_URL=http://execution-service:5001

# Docker-out-of-Docker Volume mapping configuration.
# If running locally, leave this commented out or blank.
# On a production Linux/AWS host, this must point to the absolute path of the
# execution-service directory on the HOST machine (e.g., /home/ubuntu/arena/execution-service/src/temp).
# HOST_TEMP_DIR=/home/ubuntu/arena/execution-service/src/temp

# -------------------------------------------------------------------------
# FRONTEND VITE & NGINX CONFIGURATION
# -------------------------------------------------------------------------
FRONTEND_PORT=80
VITE_API_URL=http://localhost:5000
VITE_EXECUTE_URL=http://localhost:5001
